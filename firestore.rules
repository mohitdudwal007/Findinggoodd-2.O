rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && request.auth.token.email == 'mohitdudwal007@gmail.com'; }
    function isValidId(id) { return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidMovie(data) {
      return data.keys().hasAll(['title', 'director', 'year', 'rating', 'poster', 'genre', 'size', 'downloadLink', 'createdAt', 'updatedAt'])
        && data.title is string && data.title.size() > 0 && data.title.size() <= 200
        && data.director is string && data.director.size() > 0 && data.director.size() <= 200
        && data.year is string && data.year.size() == 4
        && data.rating is number && data.rating >= 0 && data.rating <= 10
        && data.poster is string && data.poster.size() > 0 && data.poster.size() <= 1000
        && data.genre is string && data.genre.size() > 0 && data.genre.size() <= 100
        && data.size is string && data.size.size() > 0 && data.size.size() <= 50
        && data.downloadLink is string && data.downloadLink.size() > 0 && data.downloadLink.size() <= 2000
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    function isValidMovieRequest(data) {
      return data.keys().hasAll(['title', 'message', 'status', 'createdAt', 'updatedAt'])
        && data.title is string && data.title.size() > 0 && data.title.size() <= 200
        && data.message is string && data.message.size() <= 1000
        && data.status is string && data.status in ['pending', 'fulfilled', 'rejected']
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    function isValidPage(data) {
       return data.keys().hasAll(['title', 'content', 'updatedAt'])
         && data.title is string && data.title.size() > 0 && data.title.size() <= 100
         && data.content is string && data.content.size() <= 50000
         && data.updatedAt is timestamp;
    }

    match /movies/{movieId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(movieId) && isValidMovie(incoming()) && incoming().keys().size() == 10 && incoming().createdAt == request.time && incoming().updatedAt == request.time;
      allow update: if isAdmin() && isValidId(movieId) && isValidMovie(incoming()) 
        && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'director', 'year', 'rating', 'poster', 'genre', 'size', 'downloadLink', 'updatedAt'])
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time;
      allow delete: if isAdmin() && isValidId(movieId);
    }
    
    match /movieRequests/{requestId} {
      allow read: if isAdmin();
      allow create: if isValidId(requestId) && isValidMovieRequest(incoming()) && incoming().keys().size() == 5 && incoming().status == 'pending' && incoming().createdAt == request.time && incoming().updatedAt == request.time;
      allow update: if isAdmin() && isValidId(requestId) && isValidMovieRequest(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt'])
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time;
      allow delete: if isAdmin() && isValidId(requestId);
    }

    match /pages/{pageId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(pageId) && isValidPage(incoming()) && incoming().keys().size() == 3 && incoming().updatedAt == request.time;
      allow update: if isAdmin() && isValidId(pageId) && isValidPage(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'content', 'updatedAt'])
        && incoming().updatedAt == request.time;
      allow delete: if isAdmin() && isValidId(pageId);
    }
  }
}
